# Where the EmulatorJS engine + cores load from at runtime.
# Defaults to the public EmulatorJS CDN (good for the web app).
# For offline / native iOS builds, self-host the EmulatorJS `data` folder and
# point this at it (must end with a trailing slash), e.g. "/emulatorjs/".
VITE_EJS_DATA_PATH=https://cdn.emulatorjs.org/stable/data/
