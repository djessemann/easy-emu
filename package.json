{
  "name": "easy-emu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A dead-simple mobile emulator for NES, SNES, Genesis and Game Boy.",
  "scripts": {
    "dev": "vite",
    "vendor": "node scripts/vendor-emulatorjs.mjs",
    "prebuild": "node scripts/vendor-emulatorjs.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@emulatorjs/core-fceumm": "4.2.3",
    "@emulatorjs/core-gambatte": "4.2.3",
    "@emulatorjs/core-genesis_plus_gx": "4.2.3",
    "@emulatorjs/core-snes9x": "4.2.3",
    "@emulatorjs/emulatorjs": "4.2.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1"
  }
}
